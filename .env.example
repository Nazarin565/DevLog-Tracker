# LLM provider selection: "mock" (default, no key needed) | "anthropic"
LLM_PROVIDER=

# Anthropic API key — required only when LLM_PROVIDER=anthropic. Backend-only, never exposed to the client.
ANTHROPIC_API_KEY=

# Model to use when LLM_PROVIDER=anthropic. Defaults to claude-sonnet-4-6 if unset.
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
LLM_MODEL=

# Express server port (API). Web expects it at this port.
API_PORT=

# Allowed CORS origin for the web app (not "*").
WEB_ORIGIN=

# Base URL the Next.js app uses to reach the Express API.
NEXT_PUBLIC_API_URL=

# Path to the SQLite database file (relative to packages/server).
DATABASE_PATH=
