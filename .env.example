# LLM provider selection: "mock" (default, no key needed) | "anthropic"
LLM_PROVIDER=

# Anthropic API key — required only when LLM_PROVIDER=anthropic. Backend-only, never exposed to the client.
ANTHROPIC_API_KEY=

# Model to use when LLM_PROVIDER=anthropic. Defaults to claude-sonnet-4-6 if unset.
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
LLM_MODEL=

# [optional] Express server port (API). Web expects it at this port. Default: 4000
API_PORT=

# [optional] Allowed CORS origin for the web app (not "*"). Default: http://localhost:3000
WEB_ORIGIN=

# [optional] Base URL the Next.js app uses to reach the Express API. Default: http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# [optional] Path to the SQLite database file (relative to packages/server). Default: data/devlog.sqlite
DATABASE_PATH=
